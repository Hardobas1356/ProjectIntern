@using ProjectIntern.Web.ViewModels.ApplicationUser
@model InternCalendarViewModel

@{
    ViewData["Title"] = "My Calendar";

    var revealedDates = Model.WorkDays
        .Where(w => w.IsRevealed)
        .Select(w => w.Date.ToString("yyyy-MM-dd"))
        .ToList();

    var upcomingDates = Model.WorkDays
        .Where(w => !w.IsRevealed)
        .Select(w => w.Date.ToString("yyyy-MM-dd"))
        .ToList();

    var revealedMap = Model.WorkDays
        .Where(w => w.IsRevealed)
        .ToDictionary(
            w => w.Date.ToString("yyyy-MM-dd"),
            w => new { w.TopicName, w.TopicDescription }
        );
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css" />
<style>
    .day-row:hover { background-color: #f8f9fa; cursor: pointer; }
    .day-row.active { background-color: #e9ecef; }
    .upcoming-row { cursor: default; }
</style>

<div class="container-fluid px-4">
    <h1 class="mt-4">My Internship Calendar</h1>
    <ol class="breadcrumb mb-4">
        <li class="breadcrumb-item active">@Model.InternName</li>
    </ol>

    @* No speciality assigned yet *@
    @if (!Model.WorkDays.Any() && Model.SpecialityName == "N/A")
    {
        <div class="card shadow-sm text-center py-5">
            <div class="card-body">
                <i class="fas fa-hourglass-half d-block mb-3 text-primary" style="font-size:2rem;"></i>
                <h5>Your internship is being set up</h5>
                <p class="text-muted mb-0">Your administrator will assign your speciality and schedule shortly.</p>
            </div>
        </div>
    }
    else
    {
        @* Summary bar *@
        <div class="d-flex flex-wrap gap-2 align-items-center mb-4">
            <span class="badge bg-primary fs-6">@Model.SpecialityName</span>
            <span class="badge bg-secondary">@Model.WorkDays.Count() total days</span>
            <span class="badge bg-success">@Model.CompletedTopicsCount covered</span>
            <span class="badge bg-info text-dark">@upcomingDates.Count upcoming</span>
            @if (Model.InternshipStartDate.HasValue)
            {
                <span class="badge bg-light text-dark border">
                    Start: @Model.InternshipStartDate.Value.ToString("dd MMM yyyy")
                </span>
            }
            @if (Model.InternshipEndDate.HasValue)
            {
                <span class="badge bg-light text-dark border">
                    End: @Model.InternshipEndDate.Value.ToString("dd MMM yyyy")
                </span>
            }
        </div>

        @* Progress bar *@
        @if (Model.WorkDays.Any())
        {
            int pct = (int)Math.Round((double)Model.CompletedTopicsCount / Model.WorkDays.Count() * 100);
            <div class="mb-4">
                <div class="d-flex justify-content-between small text-muted mb-1">
                    <span>Progress</span>
                    <span>@Model.CompletedTopicsCount / @Model.WorkDays.Count() days</span>
                </div>
                <div class="progress" style="height:8px;">
                    <div class="progress-bar bg-success" style="width:@pct%"></div>
                </div>
            </div>
        }

        <div class="row g-4">

            @* Left — calendar *@
            <div class="col-xl-5 col-lg-6">
                <div class="card shadow-sm" style="width: 330px;">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <span><i class="fas fa-calendar-alt me-2"></i>Your schedule</span>
                        <span class="small text-muted">
                            <span class="badge bg-success me-1">●</span>Covered
                            <span class="badge bg-primary ms-1 me-1">●</span>Upcoming
                        </span>
                    </div>
                    <div class="card-body p-2">
                        <input id="calendar-input" type="text" style="display:none;" />
                    </div>
                </div>
            </div>

            @* Right — topic preview + lists *@
            <div class="col-xl-7 col-lg-6">
                <div class="row g-3">

                    @* Topic preview *@
                    <div class="col-12">
                        <div class="card shadow-sm">
                            <div class="card-header">
                                <i class="fas fa-book-open me-2"></i>Topic detail
                            </div>
                            <div class="card-body text-center text-muted" id="topic-preview" style="min-height:140px;">
                                <i class="fas fa-hand-pointer d-block mb-2 mt-3" style="font-size:1.5rem;"></i>
                                <span>Click a covered day on the calendar to see its topic</span>
                            </div>
                        </div>
                    </div>

                    @* Upcoming days *@
                    <div class="col-12">
                        <div class="card shadow-sm">
                            <div class="card-header d-flex justify-content-between align-items-center">
                                <span><i class="fas fa-clock me-2"></i>Upcoming days</span>
                                <span class="text-primary fw-semibold small">@upcomingDates.Count remaining</span>
                            </div>
                            <div style="max-height:280px; overflow-y:auto;">
                                @if (upcomingDates.Any())
                                {
                                    foreach (var day in Model.WorkDays.Where(w => !w.IsRevealed).OrderBy(d => d.Date))
                                    {
                                        <div class="day-row upcoming-row d-flex align-items-center px-3 py-2 border-bottom">
                                            <span class="badge bg-primary me-3">●</span>
                                            <div>
                                                <div class="fw-semibold small">@day.Date.ToString("dddd, dd MMM yyyy")</div>
                                                <div class="text-muted" style="font-size:0.75rem;">
                                                    <i class="fas fa-lock me-1"></i>Topic revealed on the day
                                                </div>
                                            </div>
                                        </div>
                                    }
                                }
                                else
                                {
                                    <div class="text-center text-muted py-4">
                                        <i class="fas fa-check-circle d-block mb-2 text-success" style="font-size:1.4rem;"></i>
                                        No upcoming days
                                    </div>
                                }
                            </div>
                        </div>
                    </div>

                    @* Covered topics *@
                    <div class="col-12">
                        <div class="card shadow-sm">
                            <div class="card-header d-flex justify-content-between align-items-center">
                                <span><i class="fas fa-history me-2"></i>Covered topics</span>
                                <span class="text-success fw-semibold small">@Model.CompletedTopicsCount completed</span>
                            </div>
                            <div style="max-height:280px; overflow-y:auto;">
                                @if (revealedDates.Any())
                                {
                                    foreach (var day in Model.WorkDays.Where(w => w.IsRevealed).OrderByDescending(d => d.Date))
                                    {
                                        <div class="day-row d-flex justify-content-between align-items-center px-3 py-2 border-bottom"
                                             data-date="@day.Date.ToString("yyyy-MM-dd")"
                                             onclick="previewDay('@day.Date.ToString("yyyy-MM-dd")')">
                                            <div class="d-flex align-items-center gap-3">
                                                <span class="badge bg-success">●</span>
                                                <div>
                                                    <div class="fw-semibold small">@day.Date.ToString("dddd, dd MMM yyyy")</div>
                                                    <div class="text-muted" style="font-size:0.75rem;">@day.TopicName</div>
                                                </div>
                                            </div>
                                            <i class="fas fa-chevron-right text-muted" style="font-size:0.72rem;"></i>
                                        </div>
                                    }
                                }
                                else
                                {
                                    <div class="text-center text-muted py-4">
                                        <i class="fas fa-calendar-times d-block mb-2" style="font-size:1.4rem;"></i>
                                        No covered topics yet
                                    </div>
                                }
                            </div>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <script src="~/js/admin/intern-calendar.js"></script>

    <script>
        // Inject and process Razor models onto a isolated data block
        const calendarConfig = {
            revealedDates: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(revealedDates)),
            upcomingDates: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(upcomingDates)),
            revealedMap: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(revealedMap)),
            minDate: @(Model.InternshipStartDate.HasValue ? Html.Raw($"'{Model.InternshipStartDate.Value.ToString("yyyy-MM-dd")}'") : Html.Raw("null")),
            maxDate: @(Model.InternshipEndDate.HasValue ? Html.Raw($"'{Model.InternshipEndDate.Value.ToString("yyyy-MM-dd")}'") : Html.Raw("null"))
        };

        // Attach the data map globally so the inline onclick="previewDay(...)" element handler still works seamlessly
        window.internCalendarDataMap = calendarConfig.revealedMap;

        // Initialize calendar features using the injected configuration
        initializeInternCalendar(calendarConfig);
    </script>
}