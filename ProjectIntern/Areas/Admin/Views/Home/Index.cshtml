@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="container-fluid px-4">
    <h1 class="mt-4">Admin Dashboard</h1>
    <ol class="breadcrumb mb-4">
        <li class="breadcrumb-item active">Dashboard</li>
    </ol>

    <div class="row g-3">
        <div class="col-md-4">
            <div class="card shadow-sm h-100">
                <div class="card-body d-flex flex-column">
                    <h5 class="card-title"><i class="fas fa-users me-2 text-primary"></i>Users</h5>
                    <p class="card-text text-muted">View and manage all intern accounts, assign specialities and set internship dates.</p>
                    <a asp-controller="User" asp-action="Index" class="btn btn-primary mt-auto">
                        Go to Users
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm h-100">
                <div class="card-body d-flex flex-column">
                    <h5 class="card-title"><i class="fas fa-layer-group me-2 text-purple"></i>Specialities</h5>
                    <p class="card-text text-muted">Manage internship specialities and their curriculum topics.</p>
                    <a asp-controller="Speciality" asp-action="Index" class="btn btn-primary mt-auto">
                        Go to Specialities
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>