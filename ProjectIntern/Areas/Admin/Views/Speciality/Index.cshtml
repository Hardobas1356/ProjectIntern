@using ForumApp.GCommon
@using ProjectIntern.Web.ViewModels.Admin.InternshipSpeciality
@model PaginatedResult<InternshipSpecialityViewModel>

@{
    ViewData["Title"] = "Internship Specialities";
    string searchTerm = ViewData["SearchTerm"] as string ?? "";
    bool showDeleted = (bool)(ViewData["ShowDeleted"] ?? false);
}

<div class="container-fluid px-4">
    <h1 class="mt-4">Specialities Management</h1>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item"><a asp-controller="User" asp-action="Index">Dashboard</a></li>
            <li class="breadcrumb-item active">Specialities</li>
        </ol>
        <a asp-action="Create" class="btn btn-primary">
            <i class="fas fa-plus-circle me-1"></i> Add New Speciality
        </a>
    </div>

    <div class="card mb-4 shadow-sm">
        <div class="card-header bg-dark text-white">
            <i class="fas fa-list me-1"></i> Speciality List
        </div>
        <div class="card-body">
            <form method="get" asp-action="Index" class="row g-3 mb-4">
                <div class="col-md-5">
                    <div class="input-group">
                        <input type="text" name="searchTerm" value="@searchTerm" class="form-control" placeholder="Search by name..." />
                        <button class="btn btn-outline-secondary" type="submit">
                            Search
                            <i class="fas fa-search"></i>
                        </button>
                    </div>
                </div>
                <div class="col-md-4 d-flex align-items-center">
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" name="showDeleted" value="true" id="showDeleted" @(showDeleted ? "checked" : "") onchange="this.form.submit()" />
                        <label class="form-check-label" for="showDeleted">Show Deleted Specialities</label>
                        @* Ensures the bool is sent correctly in ASP.NET Core *@
                        <input type="hidden" name="showDeleted" value="false" />
                    </div>
                </div>
            </form>

            <div class="table-responsive">
                <table class="table table-hover table-bordered align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Speciality Name</th>
                            <th class="text-center">Status</th>
                            <th class="text-center" style="width: 200px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Items.Any())
                        {
                            foreach (var speciality in Model.Items)
                            {
                                <tr class="@(speciality.IsDeleted ? " table-light opacity-75" : "")">
                                    <td class="fw-bold">@speciality.Name</td>
                                    <td class="text-center">
                                        @if (speciality.IsDeleted)
                                        {
                                            <span class="badge bg-danger">Deleted</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success">Active</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        @if (!speciality.IsDeleted)
                                        {
                                            <div class="d-flex justify-content-center gap-2">
                                                <a asp-action="Edit" asp-route-id="@speciality.Id" class="btn btn-sm btn-warning">
                                                    <i class="fas fa-edit"></i> Edit
                                                </a>
            
                                                <form asp-action="SoftDeleteSpeciality" asp-route-id="@speciality.Id" method="post"
                                                      onsubmit="return confirm('Archive this speciality?');" class="d-inline">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit" class="btn btn-sm btn-danger">
                                                        <i class="fas fa-trash"></i> Delete
                                                    </button>
                                                </form>
                                            </div>
                                        }
                                        else
                                        {
                                            <form asp-action="RestoreSpeciality" asp-route-id="@speciality.Id" method="post">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-success">
                                                    <i class="fas fa-undo"></i> Restore
                                                </button>
                                            </form>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="3" class="text-center text-muted py-4">No specialities found matching your criteria.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <nav aria-label="Page navigation" class="mt-3">
                <ul class="pagination justify-content-center">
                    <li class="page-item @(!Model.HasPreviousPage ? " disabled" : "")">
                        <a class="page-link" asp-action="Index" asp-route-pageNumber="@(Model.PageIndex - 1)" asp-route-searchTerm="@searchTerm" asp-route-showDeleted="@showDeleted">Previous</a>
                    </li>
                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        <li class="page-item @(i == Model.PageIndex ? " active" : "")">
                            <a class="page-link" asp-action="Index" asp-route-pageNumber="@i" asp-route-searchTerm="@searchTerm" asp-route-showDeleted="@showDeleted">@i</a>
                        </li>
                    }
                    <li class="page-item @(!Model.HasNextPage ? " disabled" : "")">
                        <a class="page-link" asp-action="Index" asp-route-pageNumber="@(Model.PageIndex + 1)" asp-route-searchTerm="@searchTerm" asp-route-showDeleted="@showDeleted">Next</a>
                    </li>
                </ul>
            </nav>
        </div>
    </div>
</div>
