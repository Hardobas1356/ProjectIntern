@using ProjectIntern.Web.ViewModels.Admin.ApplicationUser
@model UserEditInputModel

@{
    ViewData["Title"] = "Edit User";
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
}
@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">@TempData["SuccessMessage"]</div>
}
@if (TempData["WarningMessage"] != null)
{
    <div class="alert alert-warning">@TempData["WarningMessage"]</div>
}

<div class="container-fluid px-4">
    <h1 class="mt-4">Edit User</h1>
    <ol class="breadcrumb mb-4">
        <li class="breadcrumb-item"><a asp-area="Admin" asp-controller="User" asp-action="Index">All Users</a></li>
        <li class="breadcrumb-item active">Edit @Model.Name</li>
    </ol>

    <div class="row">
        <div class="col-xl-8 col-lg-10">
            <div class="card mb-4 shadow-sm">
                <div class="card-header bg-primary text-white">
                    <i class="fas fa-user-edit me-1"></i>
                    User Details: @Model.Name
                </div>
                <div class="card-body">
                    <form asp-action="EditUser" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                        <input type="hidden" asp-for="Id" />

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label asp-for="Name" class="form-label fw-bold"></label>
                                <input asp-for="Name" class="form-control" placeholder="Full Name" />
                                <span asp-validation-for="Name" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="University" class="form-label fw-bold"></label>
                                <input asp-for="University" class="form-control" placeholder="University Name" />
                                <span asp-validation-for="University" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-12">
                                <label asp-for="InternshipSpecialityId" class="form-label fw-bold"></label>
                                <select asp-for="InternshipSpecialityId" asp-items="Model.Specialities"
                                        class="form-select" id="specialitySelect">
                                    <option value="">-- Unassigned / Admin --</option>
                                </select>
                                <div id="speciality-warning" class="alert alert-warning mt-2 d-none">
                                    <i class="fas fa-exclamation-triangle me-1"></i>
                                    Changing the speciality will reset this intern's curriculum progress,
                                    including completed topics count and last assigned topic.
                                </div>
                                <span asp-validation-for="InternshipSpecialityId" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="row mb-4">
                            <div class="col-md-6">
                                <label asp-for="InternshipStartDate" class="form-label fw-bold"></label>
                                <input asp-for="InternshipStartDate" class="form-control" />
                                <span asp-validation-for="InternshipStartDate" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="InternshipEndDate" class="form-label fw-bold"></label>
                                <input asp-for="InternshipEndDate" class="form-control" />
                                <span asp-validation-for="InternshipEndDate" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="d-flex justify-content-between border-top pt-3">
                            <a asp-action="Index" class="btn btn-outline-secondary">
                                Back to List
                            </a>
                            <button type="submit" class="btn btn-success px-4">
                                Save Changes
                            </button>
                        </div>
                    </form>

                    <div class="d-flex gap-2 flex-wrap border-top pt-3 mt-3">

                        @if (Model.IsDeleted)
                        {
                            <form asp-action="HardDeleteUser" asp-route-id="@Model.Id" method="post"
                                  onsubmit="return confirm('This will permanently delete the user and all their data. This cannot be undone. Are you sure?');">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-danger">
                                    Delete permanently
                                </button>
                            </form>
                        }

                        @if (!Model.IsAdmin)
                        {
                            <form asp-action="MakeAdmin" asp-route-id="@Model.Id" method="post"
                                  onsubmit="return confirm('Grant admin privileges to this user?');">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-success">
                                    Make admin
                                </button>
                            </form>
                        }
                        else
                        {
                            <form asp-action="RemoveAdmin" asp-route-id="@Model.Id" method="post"
                                  onsubmit="return confirm('Remove admin privileges from this user?');">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-danger">
                                    Remove admin
                                </button>
                            </form>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        const originalSpecialityId = '@Model.InternshipSpecialityId';
        const select = document.getElementById('specialitySelect');
        const warning = document.getElementById('speciality-warning');

        select.addEventListener('change', function () {
            const changed = this.value !== originalSpecialityId;
            warning.classList.toggle('d-none', !changed);
        });
    </script>
}