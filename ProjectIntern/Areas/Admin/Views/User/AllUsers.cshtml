@using ForumApp.GCommon
@using ProjectIntern.Web.ViewModels.Admin.ApplicationUser
@model PaginatedResult<UserAdminViewModel>

@{
    ViewData["Title"] = "User Management";
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="container-fluid px-4">
    <h1 class="mt-4">User Management</h1>
    <ol class="breadcrumb mb-4">
        <li class="breadcrumb-item"><a asp-area="Admin" asp-controller="User" asp-action="Index">Dashboard</a></li>
        <li class="breadcrumb-item active">All Users</li>
    </ol>

    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <div>
                <i class="fas fa-table me-1"></i>
                Registered Application Users
            </div>
        </div>
        <div class="card-body">
            <form asp-area="Admin" asp-controller="User" asp-action="AllUsers" method="get" class="row g-3 mb-4">
                <div class="col-md-6">
                    <div class="input-group">
                        <input type="text" name="searchTerm" value="@ViewData["SearchTerm"]"
                               class="form-control" placeholder="Search by name, email or username..." />
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-search"></i> Search
                        </button>
                        @if (!string.IsNullOrWhiteSpace(ViewData["SearchTerm"]?.ToString()))
                        {
                            <a asp-action="AllUsers" class="btn btn-outline-secondary">Clear</a>
                        }
                    </div>
                </div>
            </form>

            <div class="table-responsive">
                <table class="table table-bordered table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Name</th>
                            <th>Speciality</th>
                            <th>University</th>
                            <th>Joined Date</th>
                            <th class="text-center">Progress Order</th>
                            <th class="text-center">Status</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Items.Any())
                        {
                            @foreach (var user in Model.Items)
                            {
                                <tr class="@(user.IsDeleted ? "table-secondary opacity-75" : "")">
                                    <td>
                                        <strong>@user.Name</strong>
                                        @if (user.IsDeleted)
                                        {
                                            <span class="badge bg-dark ms-1">Deleted Account</span>
                                        }
                                    </td>
                                    <td>
                                        <span class="badge bg-info text-dark">@user.InternshipSpeciality</span>
                                    </td>
                                    <td>@user.University</td>
                                    <td>@user.CreationDate</td>
                                    <td class="text-center">
                                        <span class="fw-bold text-primary">@user.LastAssignmentOrder</span>
                                    </td>
                                    <td class="text-center">
                                        @if (user.IsDeleted)
                                        {
                                            <span class="badge bg-danger">Inactive</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success">Active</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        <div class="btn-group btn-group-sm">
                                            <a asp-action="GetUserForEdit" asp-route-id="@user.Id" class="btn btn-outline-warning" title="Edit">
                                                Edit
                                            </a>
                                            @if (user.IsDeleted)
                                            {
                                                <form asp-action="RestoreUser" asp-route-id="@user.Id" method="post" onsubmit="return confirm('Restore this user?');">
                                                    <button type="submit" class="btn btn-outline-success border-start-0">Restore</button>
                                                </form>
                                            }
                                            else
                                            {
                                                <form asp-action="SoftDeleteUser" asp-route-id="@user.Id" method="post" onsubmit="return confirm('Are you sure you want to delete this user?');">
                                                    <button type="submit" class="btn btn-outline-danger border-start-0">Delete</button>
                                                </form>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="7" class="text-center py-4 text-muted">No users found matching your criteria.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (Model.TotalPages > 1)
            {
                <nav aria-label="User table navigation" class="mt-4">
                    <ul class="pagination justify-content-center">
                        <li class="page-item @(!Model.HasPreviousPage ? "disabled" : "")">
                            <a class="page-link" asp-route-pageNumber="@(Model.PageIndex - 1)" asp-route-searchTerm="@ViewData["SearchTerm"]">Previous</a>
                        </li>

                        @for (int i = 1; i <= Model.TotalPages; i++)
                        {
                            <li class="page-item @(i == Model.PageIndex ? "active" : "")">
                                <a class="page-link" asp-route-pageNumber="@i" asp-route-searchTerm="@ViewData["SearchTerm"]">@i</a>
                            </li>
                        }

                        <li class="page-item @(!Model.HasNextPage ? "disabled" : "")">
                            <a class="page-link" asp-route-pageNumber="@(Model.PageIndex + 1)" asp-route-searchTerm="@ViewData["SearchTerm"]">Next</a>
                        </li>
                    </ul>
                </nav>
                <div class="text-center text-muted small">
                    Showing @Model.FirstItemIndex to @Model.LastItemIndex of @Model.TotalItems users
                </div>
            }
        </div>
    </div>
</div>