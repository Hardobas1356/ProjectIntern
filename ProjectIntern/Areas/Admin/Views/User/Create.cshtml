@model ProjectIntern.Web.ViewModels.Admin.ApplicationUser.UserCreateAdminInputModel

@{
    ViewData["Title"] = "Create New User";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">Create New User Account</h5>
                    <a asp-action="Index" class="btn btn-sm btn-outline-light">Back to List</a>
                </div>
                <div class="card-body">
                    <form asp-action="Create" method="post">
                        @Html.AntiForgeryToken()
                        
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <h6 class="text-muted border-bottom pb-2 mb-3">Account Information</h6>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Name" class="form-label font-weight-bold"></label>
                                <input asp-for="Name" class="form-control" placeholder="John Doe" />
                                <span asp-validation-for="Name" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="Username" class="form-label"></label>
                                <input asp-for="Username" class="form-control" placeholder="johndoe123" />
                                <span asp-validation-for="Username" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Password" class="form-label"></label>
                            <input asp-for="Password" class="form-control" type="password" placeholder="Minimum 8 characters" />
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>

                        <h6 class="text-muted border-bottom pb-2 mt-4 mb-3">Internship & University Profile</h6>
                        <div class="mb-3">
                            <label asp-for="University" class="form-label"></label>
                            <input asp-for="University" class="form-control" placeholder="Technical University of Varna" />
                            <span asp-validation-for="University" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="InternshipSpecialityId" class="form-label"></label>
                            <select asp-for="InternshipSpecialityId" asp-items="Model.Specialities" class="form-select">
                                <option value="">-- Select a Speciality (Optional) --</option>
                            </select>
                            <span asp-validation-for="InternshipSpecialityId" class="text-danger small"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="InternshipStartDate" class="form-label"></label>
                                <input asp-for="InternshipStartDate" class="form-control" type="date" />
                                <span asp-validation-for="InternshipStartDate" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="InternshipEndDate" class="form-label"></label>
                                <input asp-for="InternshipEndDate" class="form-control" type="date" />
                                <span asp-validation-for="InternshipEndDate" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="d-grid gap-2 d-md-flex justify-content-md-end mt-4">
                            <a asp-action="Index" class="btn btn-light px-4 me-md-2">Cancel</a>
                            <button type="submit" class="btn btn-primary px-4">Create Account</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}