@model ProjectIntern.Web.ViewModels.Admin.WorkDay.InternCalendarAdminViewModel
@{
    ViewData["Title"] = $"Calendar – {Model.InternName}";
    var workDayDates = Model.WorkDays.Select(w => w.Date.ToString("yyyy-MM-dd")).ToList();
    var workDayMap = Model.WorkDays.ToDictionary(
        w => w.Date.ToString("yyyy-MM-dd"),
        w => new { w.TopicName, w.TopicDescription }
    );
}
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css" />


<div class="container-fluid px-4">
    <h1 class="mt-4">Calendar</h1>
    <ol class="breadcrumb mb-4">
        <li class="breadcrumb-item">
            <a asp-area="Admin" asp-controller="User" asp-action="AllUsers">All Users</a>
        </li>
        <li class="breadcrumb-item active">@Model.InternName</li>
    </ol>

    @* Intern summary *@
    <div class="d-flex flex-wrap gap-2 align-items-center mb-4">
        <span class="badge bg-primary fs-6">@Model.SpecialityName</span>
        <span class="fw-bold fs-5">@Model.InternName</span>
        <span class="badge bg-secondary">@Model.WorkDays.Count() work days</span>
        @if (Model.InternshipStartDate.HasValue)
        {
            <span class="badge bg-light text-dark border">
                Start: @Model.InternshipStartDate.Value.ToString("dd MMM yyyy")
            </span>
        }
        @if (Model.InternshipEndDate.HasValue)
        {
            <span class="badge bg-light text-dark border">
                End: @Model.InternshipEndDate.Value.ToString("dd MMM yyyy")
            </span>
        }
        @if (Model.HasCompletedCurriculum)
        {
            <span class="badge bg-success">
                Curriculum complete
            </span>
        }
        <a asp-controller="User" asp-action="AllUsers" class="btn btn-sm btn-outline-secondary ms-auto">
        Back
        </a>
    </div>

    <div class="row g-4">
        @* Left — Calendar + Actions *@
        <div class="col">
            <div class="card shadow-sm" style="width: 330px;">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <span>Select days</span>
                    <small class="text-muted">Click to select<br />Click again to deselect</small>
                </div>
                <div class="card-body p-2">
                    <input id="calendar-input" type="text" style="display:none;" />
                </div>
            </div>

            <div class="alert alert-light border mb-3 py-2" style="width: 330px" id="selection-summary">
                <span id="summary-text">No dates selected</span>
            </div>

            <div class="d-flex gap-3 flex-wrap justify-content-center" style="max-width: 330px;">
                <button class="btn btn-primary" id="btn-add" onclick="addDays()" disabled>
                    Add days
                </button>
                <button class="btn btn-outline-danger" id="btn-remove" onclick="removeDays()" disabled>
                    Remove days
                </button>
                <button class="btn btn-outline-secondary" onclick="clearSelection()">
                    Clear
                </button>
            </div>
        </div>

        @* Right — Topic preview + Work day list *@
        <div class="col-xl-7 col-lg-6">

            @* Topic preview *@
            <div class="card shadow-sm mb-3">
                <div class="card-header">
                    Topic preview
                </div>
                <div class="card-body text-center text-muted" id="topic-preview" style="min-height:140px;">
                    <span>Click a highlighted day to preview its topic</span>
                </div>
            </div>

            @* Work day list *@
            <div class="card shadow-sm">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <span>Assigned work days</span>
                    <span class="text-primary fw-semibold" id="day-count-label">@Model.WorkDays.Count() days</span>
                </div>
                <div style="max-height:380px; overflow-y:auto;">
                    @if (Model.WorkDays.Any())
                    {
                        foreach (var day in Model.WorkDays.OrderBy(d => d.Date))
                        {
                            <div class="day-row d-flex justify-content-between align-items-center px-3 py-2 border-bottom"
                                 data-date="@day.Date.ToString("yyyy-MM-dd")"
                                 onclick="previewDay('@day.Date.ToString("yyyy-MM-dd")')">
                                <div>
                                    <div class="fw-semibold small">@day.Date.ToString("dddd, dd MMM yyyy")</div>
                                    <div class="text-muted" style="font-size:0.75rem;">@day.TopicName</div>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="text-center text-muted py-5">
                            No work days assigned yet
                        </div>
                    }
                </div>
            </div>

        </div>
    </div>
</div>

<div id="toast-container" class="position-fixed bottom-0 end-0 p-3" style="z-index:9999;"></div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
<script>
    const internId = '@Model.InternId';
    const addUrl = '@Url.Action("AddDays", "WorkDay")';
    const removeUrl = '@Url.Action("RemoveDays", "WorkDay")';
    const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';
    const existingDates = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(workDayDates));
    const workDayMap = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(workDayMap));

    @if (Model.InternshipStartDate.HasValue)
    {<text>const minDate = '@Model.InternshipStartDate.Value.ToString("yyyy-MM-dd")';</text>}
    else
    {<text>const minDate = null;</text>}

    @if (Model.InternshipEndDate.HasValue)
    {<text>const maxDate = '@Model.InternshipEndDate.Value.ToString("yyyy-MM-dd")';</text>}
    else
    {<text>const maxDate = null;</text>}

    let selectedDates = [];

    const fp = flatpickr("#calendar-input", {
        mode: "multiple",
        inline: true,
        dateFormat: "Y-m-d",
        minDate: minDate,
        maxDate: maxDate,
        disableMobile: true,
        onChange: function(dates) {
            selectedDates = dates.map(d => formatDate(d));
            updateSummary();
            updateButtons();
            if (selectedDates.length === 1 && existingDates.includes(selectedDates[0]))
                previewDay(selectedDates[0]);
        },
        onDayCreate: function(dObj, dStr, fp, dayElem) {
            const dateStr = formatDate(dayElem.dateObj);
            if (existingDates.includes(dateStr)) {
                dayElem.style.background = '#cfe2ff';
                dayElem.style.color = '#0a58ca';
                dayElem.style.borderRadius = '4px';
            }
        }
    });

    function formatDate(d) { return d.toISOString().split('T')[0]; }

    function updateSummary() {
        const el = document.getElementById('summary-text');
        if (!selectedDates.length) { el.innerHTML = 'No dates selected'; return; }
        const newDates = selectedDates.filter(d => !existingDates.includes(d));
        const existing = selectedDates.filter(d => existingDates.includes(d));
        let parts = [];
        if (newDates.length) parts.push(`<strong class="text-primary">${newDates.length} new</strong>`);
        if (existing.length) parts.push(`<strong class="text-danger">${existing.length} to remove</strong>`);
        el.innerHTML = `<span class="badge bg-primary me-1">${selectedDates.length}</span> ${parts.join(' · ')} selected`;
    }

    function updateButtons() {
        document.getElementById('btn-add').disabled = !selectedDates.some(d => !existingDates.includes(d));
        document.getElementById('btn-remove').disabled = !selectedDates.some(d => existingDates.includes(d));
    }

    function clearSelection() {
        fp.clear();
        selectedDates = [];
        updateSummary();
        updateButtons();
    }

    function previewDay(dateStr) {
        document.querySelectorAll('.day-row').forEach(r => r.classList.remove('active'));
        document.querySelector(`.day-row[data-date="${dateStr}"]`)?.classList.add('active');
        const preview = document.getElementById('topic-preview');
        const data = workDayMap[dateStr];
        if (!data) { preview.innerHTML = `<p class="text-muted mt-3">No data for this day</p>`; return; }
        const formatted = new Date(dateStr + 'T00:00:00').toLocaleDateString('en-GB', { weekday:'long', day:'numeric', month:'long', year:'numeric' });
        preview.innerHTML = `
            <p class="text-muted small text-uppercase fw-semibold mb-1 mt-2">${formatted}</p>
            <h5 class="fw-bold">${data.TopicName ?? ''}</h5>
            <p class="text-muted">${data.TopicDescription ?? ''}</p>`;
    }

    async function addDays() {
        const newDates = selectedDates.filter(d => !existingDates.includes(d));
        if (!newDates.length) return;
        setLoading('btn-add', true);
        try {
            const res = await fetch(addUrl, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token },
                body: JSON.stringify({ internId, dates: newDates })
            });
            const json = await res.json();
            res.ok ? toast('success', json.message ?? 'Work days added.') : toast('danger', json.message ?? 'Failed to add work days.');
            if (res.ok) setTimeout(() => location.reload(), 1000);
        } catch { toast('danger', 'Network error. Please try again.'); }
        finally { setLoading('btn-add', false); }
    }

    async function removeDays() {
        const toRemove = selectedDates.filter(d => existingDates.includes(d));
        if (!toRemove.length) return;
        const past = toRemove.filter(d => new Date(d) < new Date(new Date().toDateString()));
        if (past.length && !confirm(`${past.length} day(s) have already passed. Removing them will not affect curriculum progress. Continue?`)) return;
        setLoading('btn-remove', true);
        try {
            const res = await fetch(removeUrl, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token },
                body: JSON.stringify({ internId, dates: toRemove })
            });
            const json = await res.json();
            res.ok ? toast('success', json.message ?? 'Work days removed.') : toast('danger', json.message ?? 'Failed to remove work days.');
            if (res.ok) setTimeout(() => location.reload(), 1000);
        } catch { toast('danger', 'Network error. Please try again.'); }
        finally { setLoading('btn-remove', false); }
    }

    function setLoading(btnId, loading) {
        const btn = document.getElementById(btnId);
        btn.disabled = loading;
        btn.innerHTML = loading ? 'Saving...' : (btn.dataset.original ?? btn.innerHTML);
        if (!loading) { btn.dataset.original = btn.innerHTML; updateButtons(); }
    }

    function toast(type, message) {
        const el = document.createElement('div');
        el.className = `alert alert-${type} alert-dismissible fade show shadow-sm`;
        el.innerHTML = `${message}<button type="button" class="btn-close" data-bs-dismiss="alert"></button>`;
        document.getElementById('toast-container').appendChild(el);
        setTimeout(() => el.remove(), 4000);
    }

    (function ensureToken() {
        if (!document.querySelector('input[name="__RequestVerificationToken"]')) {
            const f = document.createElement('form');
            f.innerHTML = '@Html.AntiForgeryToken()';
            document.body.appendChild(f);
        }
    })();
</script>
}