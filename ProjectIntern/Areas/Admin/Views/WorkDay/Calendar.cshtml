@model ProjectIntern.Web.ViewModels.Admin.WorkDay.InternCalendarAdminViewModel
@{
    ViewData["Title"] = $"Calendar – {Model.InternName}";
    var workDayDates = Model.WorkDays.Select(w => w.Date.ToString("yyyy-MM-dd")).ToList();
    var workDayMap = Model.WorkDays.ToDictionary(
        w => w.Date.ToString("yyyy-MM-dd"),
        w => new { w.TopicName, w.TopicDescription }
    );
}
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css" />


<div class="container-fluid px-4">
    <h1 class="mt-4">Calendar</h1>
    <ol class="breadcrumb mb-4">
        <li class="breadcrumb-item">
            <a asp-area="Admin" asp-controller="User" asp-action="Index">All Users</a>
        </li>
        <li class="breadcrumb-item active">@Model.InternName</li>
    </ol>

    @* Intern summary *@
    <div class="d-flex flex-wrap gap-2 align-items-center mb-4">
        <span class="badge bg-primary fs-6">@Model.SpecialityName</span>
        <span class="fw-bold fs-5">@Model.InternName</span>
        <span class="badge bg-secondary">@Model.WorkDays.Count() work days</span>
        @if (Model.InternshipStartDate.HasValue)
        {
            <span class="badge bg-light text-dark border">
                Start: @Model.InternshipStartDate.Value.ToString("dd MMM yyyy")
            </span>
        }
        @if (Model.InternshipEndDate.HasValue)
        {
            <span class="badge bg-light text-dark border">
                End: @Model.InternshipEndDate.Value.ToString("dd MMM yyyy")
            </span>
        }
        <a asp-controller="User" asp-action="Index" class="btn btn-sm btn-outline-secondary ms-auto">
            Back
        </a>
    </div>

    <div class="row g-4">
        @* Left — Calendar + Actions *@
        <div class="col">
            <div class="card shadow-sm" style="width: 330px;">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <span>Select days</span>
                    <small class="text-muted">Click to select<br />Click again to deselect</small>
                </div>
                <div class="card-body p-2">
                    <input id="calendar-input" type="text" style="display:none;" />
                </div>
            </div>

            <div class="alert alert-light border mb-3 py-2" style="width: 330px" id="selection-summary">
                <span id="summary-text">No dates selected</span>
            </div>

            <div class="d-flex gap-3 flex-wrap justify-content-center" style="max-width: 330px;">
                <button class="btn btn-primary" id="btn-add" onclick="addDays()" disabled>
                    Add days
                </button>
                <button class="btn btn-outline-danger" id="btn-remove" onclick="removeDays()" disabled>
                    Remove days
                </button>
                <button class="btn btn-outline-secondary" onclick="clearSelection()">
                    Clear
                </button>
            </div>
        </div>

        @* Right — Topic preview + Work day list *@
        <div class="col-xl-7 col-lg-6">

            @* Topic preview *@
            <div class="card shadow-sm mb-3">
                <div class="card-header">
                    Topic preview
                </div>
                <div class="card-body text-center text-muted" id="topic-preview" style="min-height:140px;">
                    <span>Click a highlighted day to preview its topic</span>
                </div>
            </div>

            @* Work day list *@
            <div class="card shadow-sm">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <span>Assigned work days</span>
                    <span class="text-primary fw-semibold" id="day-count-label">@Model.WorkDays.Count() days</span>
                </div>
                <div style="max-height:380px; overflow-y:auto;">
                    @if (Model.WorkDays.Any())
                    {
                        foreach (var day in Model.WorkDays.OrderBy(d => d.Date))
                        {
                            <div class="day-row d-flex justify-content-between align-items-center px-3 py-2 border-bottom"
                                 data-date="@day.Date.ToString("yyyy-MM-dd")"
                                 onclick="previewDay('@day.Date.ToString("yyyy-MM-dd")')">
                                <div>
                                    <div class="fw-semibold small">@day.Date.ToString("dddd, dd MMM yyyy")</div>
                                    <div class="text-muted" style="font-size:0.75rem;">@day.TopicName</div>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="text-center text-muted py-5">
                            No work days assigned yet
                        </div>
                    }
                </div>
            </div>

        </div>
    </div>
</div>

<div id="toast-container" class="position-fixed bottom-0 end-0 p-3" style="z-index:9999;"></div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <script src="~/js/admin/admin-calendar-manage.js"></script>
    
    <script>
        const adminCalendarConfig = {
        internId: '@Model.InternId',
        addUrl: '@Url.Action("AddDays", "WorkDay")',
        removeUrl: '@Url.Action("RemoveDays", "WorkDay")',
        existingDates: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(workDayDates)),
        workDayMap: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(workDayMap)),
        minDate: @(Model.InternshipStartDate.HasValue ? Html.Raw($"'{Model.InternshipStartDate.Value.ToString("yyyy-MM-dd")}'") : Html.Raw("null")),
        maxDate: @(Model.InternshipEndDate.HasValue ? Html.Raw($"'{Model.InternshipEndDate.Value.ToString("yyyy-MM-dd")}'") : Html.Raw("null")),
        antiforgeryTokenHtml: '@Html.AntiForgeryToken()'
        };

        initializeAdminCalendar(adminCalendarConfig);
    </script>
}